{
  "schemaVersion": 1,
  "id": "itemgalleryexporter",
  "version": "${version}",

  "name": "Item Gallery Exporter",
  "description": "Renders one transparent icon per item and generates gallery manifest.json / changes.json files for the Minecraft item gallery.",
  "authors": [
    "tinytank800"
  ],
  "contact": {},

  "license": "MIT",

  "environment": "client",
  "entrypoints": {
    "client": [
      "com.tinytank.itemgallery.ItemGalleryMod"
    ]
  },

  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "~1.21.1",
    "java": ">=21"
  }
}
